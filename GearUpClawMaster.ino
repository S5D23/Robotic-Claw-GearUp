// ============================================================
// GEAR UP TEAM #31242 - ROBOTIC CLAW MASTER CONTROLLER
// ============================================================
// What this program does:
// This code runs on a tiny computer called an ESP32.
// It lets you control 4 servo motors (the motors that make the robot arm move)
// using a web page on your phone or laptop.
// You connect to the robot's WiFi, open a browser, and slide sliders to move the arm.


// ============================================================
// LIBRARIES - Think of these like apps you "install" to get extra abilities
// ============================================================


// Wire.h gives the ESP32 the ability to talk to other chips using 2 wires.
// One wire carries data (the actual message), one wire keeps timing (like a drumbeat).
// We need this so the ESP32 can send commands to the servo controller chip.
#include <Wire.h>


// Adafruit_PWMServoDriver.h gives us control over a chip called PCA9685.
// The PCA9685 is a small chip that sits between the ESP32 and the servo motors.
// Its job: translate simple commands ("move to 90 degrees") into the exact
// electrical pulses that servo motors need to physically move.
// One PCA9685 chip can control up to 16 servo motors. We only use 4.
#include <Adafruit_PWMServoDriver.h>


// WiFi.h lets the ESP32 create its own WiFi network (like a phone hotspot).
// Without this, the ESP32 can't do anything wireless.
#include <WiFi.h>


// WebServer.h lets the ESP32 act like a tiny website server.
// When you open a browser and type an address, this library handles
// receiving your request and sending a response back.
#include <WebServer.h>


// html.h is our own file that contains the website code (the slider control page).
// When someone opens the control page in a browser, this code is what gets sent to them.
// It's stored here so we don't clutter this main file with website code.
#include "html.h"


// ============================================================
// CREATING THE SERVO CONTROLLER OBJECT
// ============================================================
// This line creates a variable called "pca" that represents the PCA9685 chip.
// Think of it like creating a TV remote in code - once you have it,
// you can press buttons (call functions) to control the servos.
// The "0x40" is the chip's address - like a house number on a street.
// The ESP32 uses this address to know which chip to send commands to.
// (If you had two PCA9685 chips, one would be 0x40 and the other 0x41.)
Adafruit_PWMServoDriver pca = Adafruit_PWMServoDriver(0x40);


// ============================================================
// SERVO SPEED/RANGE SETTINGS
// ============================================================
// Servo motors are controlled by sending them electrical pulses.
// The LENGTH of the pulse tells the servo what angle to go to.
// Think of it like blinking a flashlight:
//   - A short blink = move all the way left (0 degrees)
//   - A long blink = move all the way right (180 degrees)
//   - A medium blink = stay in the middle (90 degrees)
// We blink the signal 50 times every second - that's what servos expect.


// How many times per second the signal pulses (50 is the standard for servos)
#define SERVO_FREQ   50


// The shortest pulse length = servo goes to 0 degrees (full left)
// 500 means 500 microseconds (a microsecond is one millionth of a second)
#define SERVO_MIN_US 500


// The longest pulse length = servo goes to 180 degrees (full right)
// 2500 means 2500 microseconds
#define SERVO_MAX_US 2500


// ============================================================
// WHICH WIRE GOES TO WHICH SERVO
// ============================================================
// The PCA9685 chip has 16 output slots (numbered 0 to 15).
// Each slot connects to one servo motor with a wire.
// Here we give each slot a name so the code is easier to read.
// For example, instead of writing "0" to mean the lower joint,
// we write "CH_LOWER" - much easier to understand!


// Slot 0 on the chip = Lower Joint servo (the joint closest to the base)
// "inverted" means: when the slider on the web page goes UP, this servo goes DOWN
// This is done on purpose so the arm moves in a natural direction
#define CH_LOWER 0


// Slot 1 = Arm servo (the middle section of the arm that extends out)
#define CH_ARM   1


// Slot 2 = Claw servo (the gripper that opens and closes to grab things)
#define CH_CLAW  2


// Slot 3 = Base servo (rotates the whole arm left and right)
#define CH_BASE  3


// ============================================================
// WIFI NETWORK NAME AND PASSWORD
// ============================================================


// This is the name of the WiFi network the ESP32 will create.
// When you go to WiFi settings on your phone, you'll see "GearUp-Arm" in the list.
const char* AP_SSID = "GearUp-Arm";


// This is the password someone needs to type to join that WiFi network.
// Must be at least 8 characters long (that's a WiFi security rule).
const char* AP_PASS = "12345678";


// ============================================================
// SHARED VARIABLES - Things the whole program needs to remember
// ============================================================


// This creates the web server on port 80.
// Port 80 is the standard door that web browsers knock on by default.
// When you type "http://192.168.4.1" in a browser (no special port number),
// the browser automatically uses port 80.
WebServer server(80);


// This is a list of 4 numbers that remember the current angle of each servo.
// angles[0] = current angle of the Lower Joint
// angles[1] = current angle of the Arm
// angles[2] = current angle of the Claw
// angles[3] = current angle of the Base
// All start at 90 degrees, which is the middle/neutral position (pointing straight up).
int angles[4] = {90, 90, 90, 90};


